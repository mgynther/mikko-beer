{
  "name": "mikko-beer-frontend",
  "version": "0.0.0",
  "type": "module",
  "author": "Mikko Gynther",
  "scripts": {
    "dev": "VITE_BACKEND_URL=http://localhost:3001 vite",
    "build": "tsc && vite build && mv dist/manifest.json dist/assets/manifest*.json",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint --max-warnings=0 --fix .",
    "test": "VITE_BACKEND_URL=http://localhost:3001 TEST_PORT_START=35000 vitest --coverage.enabled false --environment jsdom",
    "test:ci": "CI=true VITE_BACKEND_URL=http://localhost:3001 TEST_PORT_START=30000 vitest --coverage.enabled true --environment jsdom",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.12.0",
    "async-mutex": "0.5.0",
    "io-ts": "2.2.22",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-redux": "9.3.0",
    "react-router": "7.15.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "react-test-renderer": "19.2.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "web-vitals": "5.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
