{
  "name": "mikko-beer-frontend",
  "version": "0.0.0",
  "type": "module",
  "author": "Mikko Gynther",
  "scripts": {
    "dev": "VITE_BACKEND_URL=http://localhost:3001 vite",
    "build": "tsc && vite build && mv dist/manifest.json dist/assets/manifest*.json",
    "lint": "npx eslint --max-warnings=0 --fix .",
    "test": "VITE_BACKEND_URL=http://localhost:3001 TEST_PORT_START=30000 vitest --coverage.enabled false --environment jsdom",
    "test:ci": "CI=true VITE_BACKEND_URL=http://localhost:3001 TEST_PORT_START=30000 vitest --coverage.enabled true --environment jsdom",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.11.2",
    "async-mutex": "0.5.0",
    "io-ts": "2.2.22",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "9.2.0",
    "react-router": "7.13.2",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "jsdom": "29.0.1",
    "react-test-renderer": "19.2.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "vitest": "4.1.2",
    "web-vitals": "5.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
